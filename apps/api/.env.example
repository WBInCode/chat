# Postgres
DATABASE_URL="postgresql://chatv2:chatv2_dev_password@localhost:5434/chatv2?schema=public"

# Redis
REDIS_URL="redis://localhost:6382"

# HTTP
PORT=4000
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5273"
NODE_ENV="development"

# JWT (EdDSA/Ed25519). Generate with: node scripts/generate-jwt-keys.mjs
JWT_PRIVATE_KEY_PATH="./keys/jwt_private.pem"
JWT_PUBLIC_KEY_PATH="./keys/jwt_public.pem"
JWT_ACCESS_TTL="10m"
JWT_ISSUER="chatv2"

# Refresh token cookie
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECRET="change-me-min-32-bytes-please-________"

# AES-256-GCM key for at-rest field encryption (32 raw bytes, base64).
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTES"

# MinIO / S3
S3_ENDPOINT="http://localhost:9010"
S3_ACCESS_KEY="chatv2"
S3_SECRET_KEY="chatv2_dev_password"
S3_BUCKET="chatv2-files"

# ClamAV (clamd TCP/INSTREAM)
CLAMAV_HOST="localhost"
CLAMAV_PORT=3311

# Gotenberg (LibreOffice-based document -> PDF conversion)
GOTENBERG_URL="http://localhost:3012"

# Generate with: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# AI assistant (F5-D) — 100% free tier only, both optional.
# Without either key, all AI features (summarize/@AI bot/rewrite) are
# feature-flagged off (GET /ai/status -> {enabled:false}), not a crash.
# Groq (primary): https://console.groq.com/keys — free tier, very fast.
GROQ_API_KEY=""
# Google AI Studio / Gemini (fallback, used only when Groq is rate-limited):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Hard daily budget (Redis-counted) shared across the whole deployment —
# protects the free tier from ever being exceeded.
AI_DAILY_LIMIT=300

# Voice calls (F5-E) — STUN is free and hardcoded (Google public STUN),
# no env needed. TURN is NOT implemented (P2P-only, documented limitation
# for symmetric-NAT edge cases) — nothing to configure here yet.

