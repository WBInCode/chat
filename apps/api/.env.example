# Postgres
DATABASE_URL="postgresql://chatv2:chatv2_dev_password@localhost:5434/chatv2?schema=public"

# Redis
REDIS_URL="redis://localhost:6382"

# HTTP
PORT=4000
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5273"
NODE_ENV="development"

# JWT (EdDSA/Ed25519). Generate with: node scripts/generate-jwt-keys.mjs
JWT_PRIVATE_KEY_PATH="./keys/jwt_private.pem"
JWT_PUBLIC_KEY_PATH="./keys/jwt_public.pem"
JWT_ACCESS_TTL="10m"
JWT_ISSUER="chatv2"

# Refresh token cookie
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECRET="change-me-min-32-bytes-please-________"

# AES-256-GCM key for at-rest field encryption (32 raw bytes, base64).
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTES"

# MinIO / S3
S3_ENDPOINT="http://localhost:9010"
S3_ACCESS_KEY="chatv2"
S3_SECRET_KEY="chatv2_dev_password"
S3_BUCKET="chatv2-files"

# ClamAV (clamd TCP/INSTREAM)
CLAMAV_HOST="localhost"
CLAMAV_PORT=3311

# Gotenberg (LibreOffice-based document -> PDF conversion)
GOTENBERG_URL="http://localhost:3012"

# Generate with: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
