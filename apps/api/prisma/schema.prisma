generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  HR
  MEMBER
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
}

enum ChannelRole {
  ADMIN
  MEMBER
}

model Organization {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  require2fa     Boolean      @default(false)
  messageRetentionDays Int?   // null = keep forever
  allowedEmailDomains  String? // comma-separated, null = any domain
  createdAt      DateTime     @default(now())
  members        Membership[]
  channels       Channel[]
  invites        Invite[]
  auditLogs      AuditLog[]
  roles          Role[]
  modules        OrganizationModule[]

  @@map("organizations")
}

/**
 * Per-organization module toggle (F7). Only stores explicit overrides for
 * OPTIONAL modules; a missing row means "use default" (enabled). Core modules
 * are never persisted here. When the org is linked to the wb-platform Hub,
 * these rows are synced from the Hub's Entitlements API.
 */
model OrganizationModule {
  id        String   @id @default(uuid())
  orgId     String
  moduleKey String
  enabled   Boolean  @default(true)
  source    String   @default("local") // "local" | "hub"
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleKey])
  @@index([orgId])
  @@map("organization_modules")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  displayName  String
  avatarUrl    String? // deprecated, unused — see avatarKey (S3 object key, resolved via presigned URL)
  avatarKey    String?
  jobTitle     String?
  department   String?
  phone        String?
  statusText   String?
  statusEmoji  String?
  statusExpiresAt DateTime?
  notifyMode   NotifyMode @default(ALL)
  totpSecret   String? // AES-256-GCM ciphertext, never plaintext
  totpEnabled  Boolean   @default(false)
  publicKey    String? // X25519 identity key, E2EE phase 2
  isSuperAdmin Boolean   @default(false) // platform-level god-mode (F5-H): manage orgs/memberships across the whole install, independent of any single org's roles
  deletedAt    DateTime? // account deletion: user row kept (anonymized) for referential integrity of past messages
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships    Membership[]
  channelMembers ChannelMember[]
  messages       Message[]
  sessions       Session[]
  recoveryCodes  RecoveryCode[]
  dataExports    DataExport[]
  pushSubscriptions PushSubscription[]
  scheduledMessages ScheduledMessage[]
  reminders      Reminder[]
  pollVotes      PollVote[]

  @@map("users")
}

model ScheduledMessage {
  id        String    @id @default(uuid())
  channelId String
  authorId  String
  content   String
  sendAt    DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sendAt])
  @@index([authorId])
  @@map("scheduled_messages")
}

model Reminder {
  id        String    @id @default(uuid())
  userId    String
  messageId String
  channelId String
  note      String?
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([remindAt])
  @@index([userId])
  @@map("reminders")
}

model Poll {
  id        String       @id @default(uuid())
  messageId String       @unique
  question  String
  allowMultiple Boolean  @default(false)
  closesAt  DateTime?
  createdAt DateTime     @default(now())

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options PollOption[]

  @@map("polls")
}

model PollOption {
  id       String     @id @default(uuid())
  pollId   String
  text     String
  position Int

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id           String   @id @default(uuid())
  pollOptionId String
  userId       String
  createdAt    DateTime @default(now())

  option PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, userId])
  @@map("poll_votes")
}

enum NotifyMode {
  ALL
  MENTIONS
  NONE
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Membership {
  id           String    @id @default(uuid())
  userId       String
  orgId        String
  role         OrgRole   @default(MEMBER)
  customRoleId String?
  disabledAt   DateTime?
  createdAt    DateTime  @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customRole Role?        @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([customRoleId])
  @@map("memberships")
}

model Role {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  color       String   @default("#8b5cf6")
  permissions String[]
  createdAt   DateTime @default(now())

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("roles")
}

model Invite {
  id        String   @id @default(uuid())
  orgId     String
  email     String
  role      OrgRole  @default(MEMBER)
  tokenHash String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("invites")
}

model Channel {
  id         String      @id @default(uuid())
  orgId      String
  type       ChannelType
  name       String?
  topic      String?
  createdBy  String
  archivedAt DateTime?
  createdAt  DateTime    @default(now())

  org     Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members ChannelMember[]
  messages Message[]

  @@index([orgId])
  @@map("channels")
}

model ChannelMember {
  id         String      @id @default(uuid())
  channelId  String
  userId     String
  role       ChannelRole @default(MEMBER)
  lastReadAt DateTime?
  mutedAt    DateTime?
  favorite   Boolean     @default(false)
  sortOrder  Int         @default(0) // per-user custom ordering in the sidebar channel list (F5-I)
  createdAt  DateTime    @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model Message {
  id          String    @id @default(uuid())
  channelId   String
  authorId    String
  content     String
  contentType String    @default("text")
  parentId    String?
  pinnedAt    DateTime?
  pinnedBy    String?
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  files   File[]
  embeds  LinkEmbed[]
  reactions Reaction[]
  savedBy SavedMessage[]
  poll    Poll?

  @@index([channelId, createdAt])
  @@index([parentId])
  @@index([channelId, pinnedAt])
  @@map("messages")
}

model SavedMessage {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, createdAt])
  @@map("saved_messages")
}

enum FileStatus {
  PENDING
  CLEAN
  INFECTED
  FAILED
}

model File {
  id           String     @id @default(uuid())
  orgId        String
  channelId    String
  uploaderId   String
  messageId    String?
  key          String     @unique
  name         String
  mimeType     String
  size         Int
  status       FileStatus @default(PENDING)
  width        Int?
  height       Int?
  thumbKey     String?
  previewKey   String?
  previewStatus String    @default("NONE") // NONE | PENDING | READY | FAILED
  createdAt    DateTime   @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@index([messageId])
  @@map("files")
}

model LinkEmbed {
  id          String   @id @default(uuid())
  messageId   String
  url         String
  title       String?
  description String?
  imageKey    String?
  siteName    String?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("link_embeds")
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  refreshHash  String    @unique
  familyId     String // rotation family, revoked together on reuse detection
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("sessions")
}

model RecoveryCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("recovery_codes")
}

enum ExportStatus {
  PENDING
  READY
  FAILED
}

model DataExport {
  id             String       @id @default(uuid())
  orgId          String? // null = personal cross-org export ("/me/export")
  requestedById  String
  targetUserId   String
  status         ExportStatus @default(PENDING)
  key            String? // S3 object key of the finished zip
  error          String?
  createdAt      DateTime     @default(now())
  expiresAt      DateTime

  targetUser User @relation(fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@map("data_exports")
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  meta      Json     @default("{}")
  ip        String?
  // Tamper-evident hash chain: prevHash links each entry to the previous
  // one for this org, so a DB-level edit/delete breaks the chain visibly.
  prevHash  String?
  hash      String?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("audit_logs")
}
